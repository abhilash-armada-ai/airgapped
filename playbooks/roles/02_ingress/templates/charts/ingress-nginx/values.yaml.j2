# nginx-ingress Helm values
# Generated by Ansible

controller:
  replicaCount: {{ _ingress_replicas | default(1) }}

  ingressClassResource:
    name: {{ _ingress_class_name | default('nginx') }}
    default: true
    controllerValue: "k8s.io/ingress-nginx"

{% if ingress.host_network | default(false) | bool %}
  hostNetwork: true
  dnsPolicy: ClusterFirstWithHostNet
{% endif %}

  service:
    type: {{ _ingress_service_type | default('LoadBalancer') }}
{% if _ingress_service_type | default('LoadBalancer') == 'NodePort' %}
    nodePorts:
      http: {{ ingress.http_node_port | default(http_node_port) | default(30080) }}
      https: {{ ingress.https_node_port | default(https_node_port) | default(30443) }}
{% endif %}

  admissionWebhooks:
    enabled: true

  resources:
    requests:
      cpu: {{ ingress_cpu_request | default('100m') }}
      memory: {{ ingress_memory_request | default('128Mi') }}
    limits:
      cpu: {{ ingress_cpu_limit | default('500m') }}
      memory: {{ ingress_memory_limit | default('256Mi') }}

  config:
    proxy-body-size: "0"
    proxy-read-timeout: "600"
    proxy-send-timeout: "600"
    use-forwarded-headers: "true"
