# SeaweedFS Helm values - generated by Ansible
# Single-instance S3-compatible object storage

global:
  registry: ""
  imageName: chrislusf/seaweedfs
  imagePullPolicy: IfNotPresent

master:
  enabled: true
  replicas: {{ seaweedfs_master_replicas }}
  port: 9333
  grpcPort: 19333

  data:
    type: "persistentVolumeClaim"
    size: {{ seaweedfs_master_storage_size }}
    storageClass: {{ seaweedfs_storage_class }}

  resources:
    requests:
      memory: {{ seaweedfs_master_memory_request }}
      cpu: "100m"
    limits:
      memory: {{ seaweedfs_master_memory_limit }}

volume:
  enabled: true
  replicas: {{ seaweedfs_volume_replicas }}
  port: 8080
  grpcPort: 18080

  data:
    type: "persistentVolumeClaim"
    size: {{ seaweedfs_volume_storage_size }}
    storageClass: {{ seaweedfs_storage_class }}

  resources:
    requests:
      memory: {{ seaweedfs_volume_memory_request }}
      cpu: "100m"
    limits:
      memory: {{ seaweedfs_volume_memory_limit }}

filer:
  enabled: true
  replicas: {{ seaweedfs_filer_replicas }}
  port: 8888
  grpcPort: 18888

  data:
    type: "persistentVolumeClaim"
    size: {{ seaweedfs_filer_storage_size }}
    storageClass: {{ seaweedfs_storage_class }}

  resources:
    requests:
      memory: {{ seaweedfs_filer_memory_request }}
      cpu: "100m"
    limits:
      memory: {{ seaweedfs_filer_memory_limit }}

  # Use embedded leveldb for single-instance
  filerdb:
    type: "leveldb2"

s3:
  enabled: {{ seaweedfs_s3_enabled | lower }}
  port: {{ seaweedfs_s3_port }}
  replicas: 1

  # Reference the credentials secret
  existingConfigSecret: seaweedfs-s3-credentials

  resources:
    requests:
      memory: "128Mi"
      cpu: "50m"
    limits:
      memory: "256Mi"

  ingress:
    enabled: true
    className: {{ seaweedfs_ingress_class }}
    annotations:
      nginx.ingress.kubernetes.io/proxy-body-size: "0"
      nginx.ingress.kubernetes.io/proxy-read-timeout: "600"
      nginx.ingress.kubernetes.io/proxy-send-timeout: "600"
{% if seaweedfs_tls_enabled | bool %}
      nginx.ingress.kubernetes.io/ssl-redirect: "true"
{% endif %}
    host: {{ seaweedfs_host }}
{% if seaweedfs_tls_enabled | bool %}
    tls:
      - secretName: {{ seaweedfs_tls_secret_name }}
        hosts:
          - {{ seaweedfs_host }}
{% endif %}
