# step-ca Helm values - generated by Ansible
# ACME-compatible private Certificate Authority

replicaCount: {{ step_ca_replicas }}

image:
  repository: smallstep/step-ca
  tag: ""  # Uses chart default
  pullPolicy: IfNotPresent

ca:
  name: "{{ step_ca_root_cn }}"
  address: ":9000"
  dns: {{ step_ca_host }}
  url: https://{{ step_ca_host }}
  password: {{ step_ca_provisioner_password }}

  provisioner:
    name: {{ step_ca_provisioner_name }}
    password: {{ step_ca_provisioner_password }}

  db:
    type: badgerv2
    dataSource: /home/step/db

inject:
  enabled: true
  config:
    files:
      ca.json:
        root: /home/step/certs/root_ca.crt
        federateRoots: []
        crt: /home/step/certs/intermediate_ca.crt
        key: /home/step/secrets/intermediate_ca_key
        address: ":9000"
        dnsNames:
          - {{ step_ca_host }}
          - step-certificates.{{ step_ca_namespace }}.svc.cluster.local
          - "127.0.0.1"
        logger:
          format: text
        db:
          type: badgerv2
          dataSource: /home/step/db
        authority:
          provisioners:
            - type: ACME
              name: acme
              forceCN: true
              claims: {}
        tls:
          cipherSuites:
            - TLS_ECDHE_ECDSA_WITH_CHACHA20_POLY1305
            - TLS_ECDHE_ECDSA_WITH_AES_128_GCM_SHA256
            - TLS_AES_128_GCM_SHA256
          minVersion: 1.2
          maxVersion: 1.3
          renegotiation: false
      defaults.json:
        ca-url: https://step-certificates.{{ step_ca_namespace }}.svc.cluster.local:9000
        ca-config: /home/step/config/ca.json
        fingerprint: ""
        root: /home/step/certs/root_ca.crt

persistence:
  enabled: true
  storageClass: {{ step_ca_storage_class }}
  size: {{ step_ca_storage_size }}
  accessModes:
    - ReadWriteOnce

service:
  type: ClusterIP
  port: 9000

ingress:
  enabled: true
  className: {{ step_ca_ingress_class }}
  annotations:
    nginx.ingress.kubernetes.io/backend-protocol: "HTTPS"
    nginx.ingress.kubernetes.io/proxy-ssl-verify: "off"
  hosts:
    - host: {{ step_ca_host }}
      paths:
        - path: /
          pathType: Prefix
  tls:
    - hosts:
        - {{ step_ca_host }}
      secretName: step-ca-tls

resources:
  requests:
    memory: {{ step_ca_memory_request }}
    cpu: {{ step_ca_cpu_request }}
  limits:
    memory: {{ step_ca_memory_limit }}
    cpu: {{ step_ca_cpu_limit }}
