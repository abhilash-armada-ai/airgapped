# Gitea Helm values - generated by Ansible
# Single-instance configuration

replicaCount: {{ gitea_replicas }}

image:
  repository: gitea/gitea
  tag: ""  # Uses chart default
  pullPolicy: IfNotPresent

gitea:
  admin:
    username: {{ gitea_admin_username }}
    password: {{ gitea_admin_password }}
    email: {{ gitea_admin_email }}

  config:
    APP_NAME: "Air-Gap Git Server"

    server:
      DOMAIN: {{ gitea_host }}
      ROOT_URL: https://{{ gitea_host }}/
      SSH_DOMAIN: {{ gitea_host }}
      SSH_PORT: {{ gitea_ssh_port }}

    service:
      DISABLE_REGISTRATION: true
      REQUIRE_SIGNIN_VIEW: false

    repository:
      DEFAULT_BRANCH: main

    mirror:
      ENABLED: true
      DISABLE_NEW_PULL: false
      DISABLE_NEW_PUSH: false
      DEFAULT_INTERVAL: 8h

persistence:
  enabled: true
  storageClass: {{ gitea_storage_class }}
  size: {{ gitea_storage_size }}
  accessModes:
    - ReadWriteOnce

ingress:
  enabled: true
  className: {{ gitea_ingress_class }}
  annotations:
    nginx.ingress.kubernetes.io/proxy-body-size: "0"
{% if gitea_tls_enabled | bool %}
    nginx.ingress.kubernetes.io/ssl-redirect: "true"
{% endif %}
  hosts:
    - host: {{ gitea_host }}
      paths:
        - path: /
          pathType: Prefix
{% if gitea_tls_enabled | bool %}
  tls:
    - secretName: {{ gitea_tls_secret_name }}
      hosts:
        - {{ gitea_host }}
{% endif %}

service:
  http:
    type: ClusterIP
    port: 3000
  ssh:
    type: {{ gitea_ssh_service_type }}
    port: {{ gitea_ssh_port }}

resources:
  requests:
    memory: {{ gitea_memory_request }}
    cpu: {{ gitea_cpu_request }}
  limits:
    memory: {{ gitea_memory_limit }}
    cpu: {{ gitea_cpu_limit }}

# Use internal PostgreSQL (single-instance)
postgresql:
  enabled: true
  global:
    postgresql:
      auth:
        password: gitea
        database: gitea
  primary:
    persistence:
      enabled: true
      storageClass: {{ gitea_storage_class }}
      size: {{ gitea_db_storage_size }}

# Disable Redis for single-instance
redis-cluster:
  enabled: false

postgresql-ha:
  enabled: false
