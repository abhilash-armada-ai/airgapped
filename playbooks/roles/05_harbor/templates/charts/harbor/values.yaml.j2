# Harbor Helm values - generated by Ansible
# Single-instance (non-HA) configuration

expose:
  type: ingress
  tls:
    enabled: {{ harbor_tls_enabled | lower }}
{% if harbor_tls_enabled | bool %}
    certSource: secret
    secret:
      secretName: {{ harbor_tls_secret_name }}
{% endif %}
  ingress:
    hosts:
      core: {{ harbor_host }}
    className: {{ harbor_ingress_class }}
    annotations:
      nginx.ingress.kubernetes.io/proxy-body-size: "0"
      nginx.ingress.kubernetes.io/proxy-read-timeout: "600"
      nginx.ingress.kubernetes.io/proxy-send-timeout: "600"

externalURL: https://{{ harbor_host }}

harborAdminPassword: {{ harbor_admin_password }}
secretKey: {{ harbor_secret_key }}

persistence:
  enabled: true
  resourcePolicy: "keep"
  persistentVolumeClaim:
    registry:
      storageClass: {{ harbor_storage_class }}
      size: {{ harbor_registry_storage_size }}
    database:
      storageClass: {{ harbor_storage_class }}
      size: {{ harbor_database_storage_size }}
    redis:
      storageClass: {{ harbor_storage_class }}
      size: {{ harbor_redis_storage_size }}
    trivy:
      storageClass: {{ harbor_storage_class }}
      size: {{ harbor_trivy_storage_size }}
    jobservice:
      storageClass: {{ harbor_storage_class }}
      size: {{ harbor_jobservice_storage_size }}

# Single-instance replicas
portal:
  replicas: {{ harbor_portal_replicas }}

core:
  replicas: {{ harbor_core_replicas }}

jobservice:
  replicas: {{ harbor_jobservice_replicas }}

registry:
  replicas: {{ harbor_registry_replicas }}

# Component toggles
trivy:
  enabled: {{ harbor_trivy_enabled | lower }}

notary:
  enabled: {{ harbor_notary_enabled | lower }}

chartmuseum:
  enabled: {{ harbor_chartmuseum_enabled | lower }}

# Internal database (non-HA)
database:
  type: internal

# Internal Redis (non-HA)
redis:
  type: internal

# Metrics for monitoring
metrics:
  enabled: true
  serviceMonitor:
    enabled: false
